<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EasArchiver.Gui.PasswordDialog"
        Title="Password Required"
        Icon="avares://EasArchiver.Gui/icon.ico"
        Width="400" Height="160"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height">

    <StackPanel Margin="20" Spacing="12">
        <TextBlock Text="Enter your password to start sync:" />
        <TextBox x:Name="PasswordBox" PasswordChar="*" RevealPassword="False"
                 Watermark="Password" KeyDown="OnKeyDown" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Cancel" Click="OnCancel" />
            <Button Content="OK" Click="OnOk" Classes="accent" />
        </StackPanel>
    </StackPanel>
</Window>
