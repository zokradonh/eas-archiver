<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="EasArchiver.Gui.ConfirmResetDialog"
        Title="Reset Sync State?"
        Icon="avares://EasArchiver.Gui/icon.ico"
        Width="380" Height="140"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height">

    <StackPanel Margin="20" Spacing="12">
        <TextBlock TextWrapping="Wrap">
            Reset sync state? The next sync will be a full re-fetch of all folders.
        </TextBlock>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="Reset" Click="OnConfirm" Foreground="#C0392B" />
            <Button Content="Cancel" Click="OnCancel" Classes="accent" IsDefault="True" />
        </StackPanel>
    </StackPanel>
</Window>
