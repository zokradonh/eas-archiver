<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EasArchiver.Gui.ViewModels"
        x:Class="EasArchiver.Gui.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="EAS Email Archiver"
        Width="750" Height="700" MinWidth="550" MinHeight="500">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <DockPanel Margin="16">

        <!-- ── Status bar ──────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom" Margin="0,8,0,0" Padding="8,4"
                Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                CornerRadius="4">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding ProgressText}"
                           FontStyle="Italic" Opacity="0.8" Margin="12,0"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="{Binding RequestCountText}"
                           Opacity="0.6" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ── Main content ────────────────────────────────────────────── -->
        <Grid RowDefinitions="Auto,*,Auto">

            <!-- Config section -->
            <Border Grid.Row="0" Padding="12" CornerRadius="6"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="1" Margin="0,0,0,8">
                <StackPanel Spacing="8">
                    <TextBlock Text="Configuration" FontWeight="SemiBold" FontSize="16" />

                    <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                          RowSpacing="6" ColumnSpacing="8">

                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Server URL" />
                        <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding ServerUrl}"
                                   Watermark="https://eas.example.com/Microsoft-Server-ActiveSync" />

                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Domain" />
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding Domain}"
                                   Watermark="(leave empty if not required)" />

                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Username" />
                        <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding Username}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Archive Directory" />
                        <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding ArchiveDirectory}"
                                   Watermark="mail_archive or D:\MailArchive" />

                        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Window Size" />
                        <NumericUpDown Grid.Row="4" Grid.Column="1" Value="{Binding WindowSize}"
                                       Minimum="1" Maximum="500" HorizontalAlignment="Left" Width="120" />

                        <CheckBox Grid.Row="5" Grid.Column="1" IsChecked="{Binding FixHeaders}"
                                  Content="Fix non-ASCII MIME headers (RFC 2047)" />

                        <CheckBox Grid.Row="6" Grid.Column="1" IsChecked="{Binding SavePassword}"
                                  IsEnabled="{Binding CanSavePassword}"
                                  Content="Remember password (Windows DPAPI, current user only)"
                                  ToolTip.Tip="Encrypts the password with Windows Data Protection API — only your Windows user account can decrypt it" />
                    </Grid>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                        <Button Content="Save Config" Command="{Binding SaveConfigCommand}" />
                        <Button Content="Reload Config" Command="{Binding LoadConfigCommand}" />
                        <Border Width="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                Margin="4,2" />
                        <Button Content="List Folders" Command="{Binding ListFoldersCommand}" />
                        <Button Content="Start Sync" Command="{Binding StartSyncCommand}"
                                Classes="accent" />
                        <Button Content="Stop" Command="{Binding StopSyncCommand}" />
                        <Border Width="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                Margin="4,2" />
                        <Button Content="Reset Sync State" Command="{Binding ResetSyncStateCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Folder selection — fills remaining space -->
            <Border Grid.Row="1" Padding="8" CornerRadius="6"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="1" Margin="0,0,0,8"
                    IsVisible="{Binding HasFolders}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                        <TextBlock Text="Folders" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Content="All" Command="{Binding SelectAllFoldersCommand}"
                                Padding="8,2" FontSize="12" />
                        <Button Content="None" Command="{Binding SelectNoneFoldersCommand}"
                                Padding="8,2" FontSize="12" />
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Folders}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:FolderItemViewModel">
                                <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding Path}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Log — collapsible expander at bottom -->
            <Expander Grid.Row="2" Header="Log" IsExpanded="{Binding ShowLog}"
                      Margin="0,0,0,0" Padding="0">
                <Border Padding="8" CornerRadius="0,0,6,6"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="1,0,1,1"
                        Height="180">
                    <ListBox ItemsSource="{Binding LogLines}"
                             FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </Border>
            </Expander>

        </Grid>
    </DockPanel>
</Window>
