<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EasArchiver.Gui.ViewModels"
        x:Class="EasArchiver.Gui.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="{Binding AppVersion, StringFormat='EAS Email Archiver v{0}'}"
        Icon="avares://EasArchiver.Gui/icon.ico"
        Width="720" Height="700" MinWidth="520" MinHeight="560">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+L" Command="{Binding ToggleLogCommand}" />
    </Window.KeyBindings>

    <Window.Styles>
        <Style Selector="Ellipse.spinner">
            <Setter Property="Opacity" Value="0" />
        </Style>
        <Style Selector="Ellipse.spinner.active">
            <Setter Property="Opacity" Value="1" />
            <Style.Animations>
                <Animation Duration="0:0:1" IterationCount="INFINITE">
                    <KeyFrame Cue="0%">
                        <Setter Property="(RotateTransform.Angle)" Value="0.0" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="(RotateTransform.Angle)" Value="360.0" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </Window.Styles>

    <DockPanel Margin="16">

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto,Auto,Auto" Margin="0,0,0,12">
            <!-- Account chip -->
            <Border Grid.Column="0" Padding="10,4" CornerRadius="12"
                    Background="{DynamicResource SystemControlBackgroundListLowBrush}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="●" FontSize="14" VerticalAlignment="Center"
                               Foreground="#22c55e" IsVisible="{Binding IsConfigured}" />
                    <TextBlock Text="●" FontSize="14" VerticalAlignment="Center"
                               Foreground="#ef4444" IsVisible="{Binding !IsConfigured}" />
                    <TextBlock Text="{Binding AccountSummary}" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Updates -->
            <Button Grid.Column="2" Content="↑ Updates" Padding="10,4" FontSize="12"
                    Command="{Binding CheckForUpdatesCommand}"
                    IsVisible="{Binding !UpdateAvailable}"
                    ToolTip.Tip="Check for updates" />
            <Button Grid.Column="2"
                    Content="{Binding UpdateVersion, StringFormat='↑ Install v{0}'}"
                    Command="{Binding ApplyUpdateCommand}"
                    Classes="accent" Padding="10,4" FontSize="12"
                    IsVisible="{Binding UpdateAvailable}" />

            <!-- Settings gear -->
            <Button Grid.Column="3" Content="⚙" FontSize="18" Padding="10,2" Margin="6,0,0,0"
                    Click="OnOpenSettings"
                    ToolTip.Tip="Settings" />

            <!-- Log toggle -->
            <Button Grid.Column="4" Content="🛈" FontSize="14" Padding="10,2" Margin="6,0,0,0"
                    Command="{Binding ToggleLogCommand}"
                    ToolTip.Tip="Show diagnostic log (Ctrl+L)" />
        </Grid>

        <!-- ── Status bar ─────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom" Margin="0,12,0,0" Padding="10,6"
                Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                CornerRadius="4">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding ProgressText}"
                           FontStyle="Italic" Opacity="0.8" Margin="12,0"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="{Binding RequestCountText}"
                           Opacity="0.6" VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ── Log overlay (toggleable) ───────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom" Margin="0,8,0,0" Padding="8" CornerRadius="6"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1"
                Height="180"
                IsVisible="{Binding ShowLog}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Diagnostic log" FontWeight="SemiBold"
                           Margin="0,0,0,4" />
                <ListBox ItemsSource="{Binding LogLines}"
                         FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12"
                         ScrollViewer.VerticalScrollBarVisibility="Auto" />
            </DockPanel>
        </Border>

        <!-- ── Main content ───────────────────────────────────────────────── -->
        <Grid RowDefinitions="Auto,Auto,*">

            <!-- Big Sync button area -->
            <Border Grid.Row="0" Padding="20" CornerRadius="8"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="1" Margin="0,0,0,12">
                <StackPanel Spacing="10" HorizontalAlignment="Center">

                    <!-- Big circular button — the whole disk is clickable -->
                    <Button Command="{Binding ToggleSyncCommand}"
                            Width="140" Height="140" Padding="0"
                            CornerRadius="70"
                            HorizontalAlignment="Center"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            ToolTip.Tip="{Binding SyncButtonText}">
                        <Grid>
                            <!-- Idle ring -->
                            <Ellipse Width="120" Height="120" StrokeThickness="3"
                                     Stroke="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                     IsVisible="{Binding ShowIdleRing}" />

                            <!-- Spinner while syncing — static background ring -->
                            <Ellipse Width="120" Height="120" StrokeThickness="6"
                                     Stroke="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                     IsVisible="{Binding IsSyncing}" />
                            <!-- Spinner while syncing — rotating arc (always in tree, opacity-toggled, rotated in code-behind) -->
                            <Ellipse x:Name="SpinnerArc"
                                     Classes="spinner"
                                     Classes.active="{Binding IsSyncing}"
                                     Width="120" Height="120"
                                     StrokeThickness="6"
                                     Stroke="#3b82f6"
                                     StrokeDashArray="12,80"
                                     RenderTransformOrigin="50%,50%"
                                     IsHitTestVisible="False">
                                <Ellipse.RenderTransform>
                                    <RotateTransform />
                                </Ellipse.RenderTransform>
                            </Ellipse>

                            <!-- Success: green disk + checkmark -->
                            <Ellipse Width="130" Height="130" Fill="#22c55e"
                                     IsVisible="{Binding LastSyncSuccess}" />
                            <TextBlock Text="✓" FontSize="72" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       IsVisible="{Binding LastSyncSuccess}" />

                            <!-- Error: red disk + X -->
                            <Ellipse Width="130" Height="130" Fill="#ef4444"
                                     IsVisible="{Binding LastSyncError}" />
                            <TextBlock Text="✕" FontSize="64" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       IsVisible="{Binding LastSyncError}" />

                            <!-- Idle: play icon -->
                            <TextBlock Text="▶" FontSize="48" Opacity="0.8"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Margin="8,0,0,0"
                                       IsVisible="{Binding ShowIdleRing}" />

                            <!-- Syncing: stop icon -->
                            <TextBlock Text="■" FontSize="48" Opacity="0.8"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       IsVisible="{Binding IsSyncing}" />
                        </Grid>
                    </Button>

                    <!-- Label below -->
                    <TextBlock Text="{Binding SyncButtonText}"
                               FontSize="14" FontWeight="SemiBold" Opacity="0.8"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Folder list controls -->
            <Border Grid.Row="2" Padding="12" CornerRadius="8"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="1">
                <DockPanel>
                    <!-- Header row -->
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                        <TextBlock Grid.Column="0" Text="{Binding FoldersHeader}"
                                   FontWeight="SemiBold" FontSize="14"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Refresh"
                                Command="{Binding ListFoldersCommand}"
                                Padding="10,4" FontSize="12"
                                ToolTip.Tip="Fetch current folder list from the server" />
                    </Grid>

                    <!-- Sync-all toggle -->
                    <CheckBox DockPanel.Dock="Top" IsChecked="{Binding SyncAll}"
                              Content="Sync all folders (even ones created in the future)"
                              Margin="0,0,0,8" />

                    <!-- Select all/none + reset state -->
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,Auto,*,Auto" Margin="0,0,0,6"
                          IsEnabled="{Binding !SyncAll}">
                        <Button Grid.Column="0" Content="All"
                                Command="{Binding SelectAllFoldersCommand}"
                                Padding="10,3" FontSize="12" />
                        <Button Grid.Column="1" Content="None" Margin="6,0,0,0"
                                Command="{Binding SelectNoneFoldersCommand}"
                                Padding="10,3" FontSize="12" />
                        <Button Grid.Column="3" Content="Reset sync state"
                                Command="{Binding ResetSyncStateCommand}"
                                Padding="10,3" FontSize="12"
                                ToolTip.Tip="Forget all SyncKeys — next sync will be a full re-fetch" />
                    </Grid>

                    <!-- The list -->
                    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="1" CornerRadius="4"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                        <Grid>
                            <ListBox ItemsSource="{Binding Folders}"
                                     IsEnabled="{Binding !SyncAll}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding" Value="8,4" />
                                    </Style>
                                    <Style Selector="ListBoxItem:nth-child(2n)">
                                        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}" />
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:FolderItemViewModel">
                                        <Grid ColumnDefinitions="Auto,Auto,Auto,*">
                                            <!-- depth indent spacer -->
                                            <Border Grid.Column="0" Width="{Binding IndentMargin}" />
                                            <CheckBox Grid.Column="1" IsChecked="{Binding IsSelected}"
                                                      VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBlock Grid.Column="2" Text="📁" FontSize="14"
                                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ParentPath}" Opacity="0.5" />
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Margin="4,0,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <!-- Empty state hint -->
                            <TextBlock IsVisible="{Binding !HasFolders}"
                                       Text="No folders loaded yet. Click 'Refresh' to fetch the folder list from the server."
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Opacity="0.6" Margin="20" TextWrapping="Wrap"
                                       TextAlignment="Center" />
                        </Grid>
                    </Border>
                </DockPanel>
            </Border>

        </Grid>
    </DockPanel>
</Window>
